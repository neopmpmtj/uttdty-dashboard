# Dashboard-local secrets (do not reuse voice diary SECRET_KEY or MASTER_ENCRYPTION_KEY)
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000

# Same Google OAuth client as voice diary (ID + secret from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must match Google Cloud Console exactly (scheme, host, path). Use www or non-www consistently
# e.g. https://www.uttdty.com/accounts/google/callback/
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/accounts/google/callback/

# Fernet key for encrypting Google tokens at rest (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
MASTER_ENCRYPTION_KEY=

# Optional TLS (production)
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
