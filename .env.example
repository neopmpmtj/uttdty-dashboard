# Dashboard-local secrets (do not reuse voice diary SECRET_KEY or MASTER_ENCRYPTION_KEY)
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000

# Same Google OAuth client as voice diary (ID + secret from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must match Google Cloud Console "Authorized redirect URIs" exactly (one string; no commas).
# Django serves the callback route at this path — see config/urls.py (oauth_google_callback) and optionally accounts.urls.
#
# Examples (choose ONE and duplicate that exact URI in Console):
#   Local: http://127.0.0.1:8000/src.accounts/google/callback/
#         or http://127.0.0.1:8000/accounts/google/callback/  (+ register the path you picked)
# Production (this project registers https://…/src.accounts/google/callback/ in Console):
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/src.accounts/google/callback/

# Fernet key for encrypting Google tokens at rest (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
MASTER_ENCRYPTION_KEY=

# If set (e.g. www.uttdty.com), redirects bare apex (uttdty.com) → www so OAuth uses one host.
CANONICAL_SITE_HOST=

# Optional TLS (production)
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
